# Sourced by deploy-dineros-gke before envsubst. Non-secret K8s refs and layout only.
# CI also exports: GCP_PROJECT_ID, IMAGE_TAG.

export K8S_NAMESPACE=dineros-staging
export APP_LABEL=dineros-staging
export MAIN_DEPLOYMENT_NAME=dineros-staging-deployment
export MAIN_CONTAINER_NAME=dineros-staging-container
export MICRO_DEPLOYMENT_NAME=dineros-microservice-staging-deployment
export MICRO_APP_LABEL=dineros-microservice-staging
export MICRO_CONTAINER_NAME=dineros-microservice-staging-container
export SERVICE_NAME=dineros-staging-service
export INGRESS_NAME=dineros-staging-ingress
export SERVICE_ACCOUNT_K8S=dineros-staging
export MAIN_REPLICAS=1

export SECRET_APP=dineros-staging-secrets
export SECRET_DB=staging-db-secrets
export SECRET_JWT=staging-gs-secrets
export SECRET_DATABASE_MAIN=dineros-staging-mysql
export SECRET_DATABASE_MICRO=dineros-staging-mysql
export SECRET_GA=google-service-account-staging

export DEPLOY_ENV_VALUE=staging
export NUXT_PUBLIC_SITE_URL=https://staging.dineros.cc
export INGRESS_TLS_SECRET_NAME=dineros-staging-tls

export PRIMARY_HOST=staging.dineros.cc
export SECONDARY_INGRESS_RULE=""
export TLS_HOSTS_LIST=$'        - staging.dineros.cc'

export OPTIONAL_NUXT_PUBLIC_DEPLOY_ENV_ENTRY=$'            - name: NUXT_PUBLIC_DEPLOY_ENV\n              value: "staging"\n'
export OPTIONAL_E2E_SEED_ENTRY=$'            - name: E2E_SEED_TOKEN\n              valueFrom:\n                secretKeyRef:\n                  name: dineros-staging-secrets\n                  key: E2E_SEED_TOKEN\n                  optional: true\n'
