# Sourced by deploy-dineros-gke before envsubst. Non-secret K8s refs and layout only.
# CI also exports: GCP_PROJECT_ID, IMAGE_TAG.

export K8S_NAMESPACE=dineros
export APP_LABEL=dineros-production
export MAIN_DEPLOYMENT_NAME=dineros-production-deployment
export MAIN_CONTAINER_NAME=dineros-production-container
export MICRO_DEPLOYMENT_NAME=dineros-microservice-production-deployment
export MICRO_APP_LABEL=dineros-microservice-production
export MICRO_CONTAINER_NAME=dineros-microservice-production-container
export SERVICE_NAME=dineros-production-service
export MICRO_SERVICE_NAME=dineros-microservice-production-svc
export INGRESS_NAME=dineros-production-ingress
export SERVICE_ACCOUNT_K8S=dineros
export MAIN_REPLICAS=3

export SECRET_APP=dineros-secrets
export SECRET_DB=production-db-secrets
export SECRET_JWT=production-gs-secrets
export SECRET_DATABASE_MAIN=dineros-secrets
export SECRET_DATABASE_MICRO=dineros-secrets
export SECRET_GA=google-service-account

export DEPLOY_ENV_VALUE=production
export NUXT_PUBLIC_SITE_URL=https://dineros.cc
export INGRESS_TLS_SECRET_NAME=dineros-production-tls

export PRIMARY_HOST=dineros.cc
export SECONDARY_INGRESS_RULE=$'    - host: www.dineros.cc\n      http:\n        paths:\n          - backend:\n              service:\n                name: dineros-production-service\n                port:\n                  name: http\n            path: /\n            pathType: ImplementationSpecific'
export TLS_HOSTS_LIST=$'        - dineros.cc\n        - www.dineros.cc'

export OPTIONAL_NUXT_PUBLIC_DEPLOY_ENV_ENTRY=""
export OPTIONAL_E2E_SEED_ENTRY=""
