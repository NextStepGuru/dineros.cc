[mysqld]
# Character set and collation
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# InnoDB settings (Google Cloud SQL optimized)
innodb_buffer_pool_size = 1G
innodb_redo_log_capacity = 536870912
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_io_capacity = 2000
innodb_io_capacity_max = 4000

# Connection settings
max_connections = 1000
max_allowed_packet = 64M
max_connect_errors = 1000000

# Security settings (Google Cloud SQL compatible)
require_secure_transport = OFF
local_infile = 0
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO,ONLY_FULL_GROUP_BY

# Binary logging (for replication)
log_bin = mysql-bin
binlog_row_image = FULL
binlog_expire_logs_seconds = 604800
max_binlog_size = 100M

# Slow query log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2

# General settings
default-time-zone = '+00:00'
authentication_policy = mysql_native_password

# Performance schema
performance_schema = ON

# Caching (Google Cloud SQL optimized)
table_open_cache = 4000
table_definition_cache = 2000

# Thread settings
thread_cache_size = 100

# Buffer settings
sort_buffer_size = 2M
read_buffer_size = 128K
read_rnd_buffer_size = 256K
join_buffer_size = 1M

# Temporary table settings
tmp_table_size = 64M
max_heap_table_size = 64M

# Lock settings
innodb_lock_wait_timeout = 50
lock_wait_timeout = 31536000

# Audit logging (Google Cloud SQL style)
# audit_log = FORCE_PLUS_PERMANENT
# audit_log_file = /var/log/mysql/audit.log
# audit_log_format = JSON
# audit_log_policy = LOGINS
