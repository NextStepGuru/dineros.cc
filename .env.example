# =============================================================================
# Dineros.cc Environment Variables
# =============================================================================

# =============================================================================
# Application Configuration
# =============================================================================
NODE_ENV=development
DEPLOY_ENV=local
NUXT_PUBLIC_DEPLOY_ENV=local
PORT=3000

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL="mysql://dineros:dineros@localhost:3306/dineros"

# Database Encryption Keys (for field encryption)
DB_ENCRYPTION_KEY="your-db-encryption-key-here"
DB_DECRYPTION_KEY_1="your-db-decryption-key-1-here"
DB_DECRYPTION_KEY_2="your-db-decryption-key-2-here"
DB_DECRYPTION_KEY_3="your-db-decryption-key-3-here"
DB_DECRYPTION_KEY_4="your-db-decryption-key-4-here"
DB_DECRYPTION_KEY_5="your-db-decryption-key-5-here"

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# NATS Configuration
# =============================================================================
NATS_URL="nats://localhost:4222"

# =============================================================================
# Plaid Integration
# =============================================================================
PLAID_CLIENT_ID="your-plaid-client-id-here"
PLAID_SECRET="your-plaid-secret-here"
# Optional: webhook URL (e.g. https://your-domain.com/api/webhook/plaid). If unset, derived from NUXT_PUBLIC_SITE_URL.
# PLAID_WEBHOOK_URL="https://your-domain.com/api/webhook/plaid"

# =============================================================================
# Email Configuration (Postmark)
# =============================================================================
POSTMARK_SERVER_TOKEN="your-postmark-server-token-here"
POSTMARK_WEBHOOK_SECRET="your-postmark-webhook-secret-here"
# Optional: BCC on signup welcome email (comma-separated for multiple)
# SIGNUP_WELCOME_BCC="you@example.com"

# =============================================================================
# Twilio Configuration
# =============================================================================
TWILIO_ACCOUNT_SID="your-twilio-account-sid-here"
TWILIO_AUTH_TOKEN="your-twilio-auth-token-here"

# =============================================================================
# Google Cloud Configuration
# =============================================================================
GCP_PROJECT_ID="your-gcp-project-id"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/service-account.json"

# =============================================================================
# Development & Debugging
# =============================================================================
# Optional; only applied when DEPLOY_ENV=local. Use for deterministic replay (fixed "now" and timezone).
# TEST_DATE=2025-08-15T12:00:00Z
# TEST_TIMEZONE=America/New_York
# Replay via API: POST /api/recalculate with body { accountId, fixedNow?, timezone?, startDate?, endDate? } or GET /api/tasks/recalculate?fixedNow=...&timezone=...&startDate=...&endDate=...
DEBUG="dineros:*"
SHOW_BULL_MQ_ADMIN=true
PROJECT_NAME="dineros"

# =============================================================================
# Docker Compose Database Configuration
# =============================================================================
MYSQL_ROOT_PASSWORD=dineros
MYSQL_DATABASE=dineros
MYSQL_USER=dineros
MYSQL_PASSWORD=dineros

# =============================================================================
# Playwright E2E (local: leave PLAYWRIGHT_BASE_URL unset — config starts `pnpm dev`)
# =============================================================================
# PLAYWRIGHT_BASE_URL=https://staging.dineros.cc
# Required for `pnpm test:e2e`: POST /api/e2e/seed and /api/e2e/cleanup (staging, or local with E2E=1). Set in GitHub Actions as `E2E_SEED_TOKEN` and in staging K8s secrets.
# E2E_SEED_TOKEN=
# Optional legacy (unused by current suite):
# E2E_STAGING_USER_EMAIL=
# E2E_STAGING_USER_PASSWORD=

# =============================================================================
# OpenAI (Plaid enrichment, vehicle value; optional — features skip if unset)
# =============================================================================
# OPENAI_API_KEY="sk-..."
# Optional model overrides (defaults: gpt-5-nano)
# OPENAI_PLAID_TX_MODEL=gpt-5-nano
# OPENAI_VEHICLE_VALUE_MODEL=gpt-5-nano
