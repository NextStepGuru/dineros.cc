    "papaparse": "^5.5.3",
    "pinia": "^3.0.3",
    "plaid": "^31.1.0",
    "postmark": "^4.0.5",
    "pug": "^3.0.3",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "tsx": "^4.20.3",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "vitest-environment-nuxt": "^1.0.1",
    "vue": "^3.5.18",
    "vue-eslint-parser": "^10.2.0",
