    "@nuxt/eslint": "^1.7.0",
    "@nuxt/eslint-config": "^1.7.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxt/ui-pro": "^3.2.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@pinia/nuxt": "^0.11.2",
    "@playwright/test": "^1.54.1",
    "@types/archiver": "^6.0.3",
    "@types/dotenv": "^8.2.3",
