    "test:e2e:update-snapshots": "pnpm --filter dineros-app test:e2e:update-snapshots",
    "test:e2e:update-snapshots:staging": "pnpm --filter dineros-app test:e2e:update-snapshots:staging",
    "test:e2e:update-snapshots:staging:visual": "pnpm --filter dineros-app test:e2e:update-snapshots:staging:visual",
    "test:e2e:full": "pnpm --filter dineros-app test:e2e:full",
    "test:e2e:mobile": "pnpm --filter dineros-app test:e2e:mobile",
