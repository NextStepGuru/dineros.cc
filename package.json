{
  "name": "dineros-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "test": "vitest --run --config vitest.config.all.ts",
    "test:coverage": "vitest --run --coverage --config vitest.config.all.ts",
    "test:coverage:watch": "vitest --coverage --config vitest.config.ts",
    "coverage:view": "open coverage/index.html",
    "coverage:report": "vitest --run --coverage --reporter=verbose --config vitest.config.all.ts",
    "coverage:help": "node scripts/view-coverage.js help",
    "coverage:open": "node scripts/view-coverage.js open",
    "coverage:generate": "node scripts/view-coverage.js generate:all",
    "coverage:serve": "node scripts/serve-coverage.js",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "upgrade": "npx ncu -u -t minor -x x",
    "reset-database": "prisma migrate reset --force",
    "backup": "curl localhost:3000/api/tasks/backup",
    "generate-jwt-secret": "node -e \"console.log(require('crypto').randomBytes(256).toString('base64'));\"",
    "pre-commit": "node scripts/check-mixed-commit.js",
    "test:forecast": "tsx server/services/forecast/__tests__/test-runner.ts",
    "test:forecast:performance": "tsx server/services/forecast/__tests__/test-runner.ts --performance",
    "test:forecast:unit": "vitest run server/services/forecast/__tests__/modernCache.unit.test.ts",
    "test:forecast:integration": "vitest run server/services/forecast/__tests__/forecastEngine.integration.test.ts",
    "test:forecast:all": "npm run test:forecast:unit && npm run test:forecast:integration && npm run test:forecast",
    "test:forecast:watch": "vitest server/services/forecast/__tests__/",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "security:scan": "./scripts/trufflehog-enhanced.sh",
    "reset-encrypted-users": "tsx scripts/reset-encrypted-users-after-restore.ts",
    "ci:local": "./scripts/ci-local.sh",
    "ci:local:lint": "./scripts/ci-local.sh --lint-only",
    "ci:local:test": "./scripts/ci-local.sh --test-only",
    "ci:local:pre-commit": "./scripts/ci-local.sh --pre-commit-only"
  },
  "dependencies": {
    "@47ng/codec": "^1.1.0",
    "@bull-board/api": "^6.20.5",
    "@bull-board/h3": "^6.20.5",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@prisma/client": "^6.19.2",
    "archiver": "^7.0.1",
    "bankers-rounding": "^0.1.3",
    "bullmq": "^5.71.0",
    "fast-glob": "^3.3.3",
    "googleapis": "^155.0.1",
    "h3": "^1.15.6",
    "husky": "^9.1.7",
    "moment": "^2.30.1",
    "moment-precise-range-plugin": "^1.3.0",
    "moment-timezone": "^0.6.0",
    "nuxt-cron": "^1.8.0",
    "ofetch": "^1.5.1",
    "pkg-types": "^2.3.0",
    "prisma": "^6.19.2",
    "prisma-field-encryption": "^1.6.0",
    "scule": "^1.3.0",
    "speakeasy": "^2.0.0",
    "tailwindcss": "^4.2.1",
    "vuedraggable": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@47ng/cloak": "^1.2.0",
    "@dazlab-team/loan-calc": "^0.1.5",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/logging-winston": "^6.0.1",
    "@google-cloud/storage": "^7.19.0",
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/simple-icons": "^1.2.74",
    "@jcss/vue-plaid-link": "^1.1.3",
    "@node-rs/argon2": "^2.0.2",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/test-utils": "^3.23.0",
    "@nuxt/ui-pro": "^3.3.7",
    "@paralleldrive/cuid2": "^2.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^6.0.4",
    "@types/dotenv": "^8.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/compiler-sfc": "^3.5.30",
    "@vue/language-plugin-pug": "^3.2.5",
    "@vue/server-renderer": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "debug": "^4.4.3",
    "dotenv": "^17.3.1",
    "eslint-plugin-vue-pug": "^0.6.2",
    "happy-dom": "^18.0.1",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "nats": "^2.29.3",
    "npm-check-updates": "^19.6.3",
    "nuxt": "^4.4.2",
    "papaparse": "^5.5.3",
    "pinia": "^3.0.4",
    "plaid": "^37.0.0",
    "postmark": "^4.0.7",
    "pug": "^3.0.4",
    "qrcode": "^1.5.4",
    "slugify": "^1.6.6",
    "tsx": "^4.21.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "vitest-environment-nuxt": "^1.0.1",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^4.6.4",
    "winston": "^3.19.0"
  },
  "pnpm": {
    "hoist-pattern": [
      "*prisma*"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=24.14.0 <25.0.0"
  }
}
