    "@nuxt/ui": "^3.2.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@prisma/client": "^6.12.0",
    "archiver": "^7.0.1",
    "bankers-rounding": "^0.1.3",
    "bullmq": "^5.56.5",
