    "googleapis": "^128.0.0",
    "husky": "^9.1.7",
    "moment": "^2.30.1",
    "moment-precise-range-plugin": "^1.3.0",
    "nuxt-cron": "^1.8.0",
    "nuxt-lodash": "^2.5.3",
    "ofetch": "^1.4.1",
    "pkg-types": "^2.2.0",
