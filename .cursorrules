# Cursor Rules for Dineros Project

# Editor Settings
editor.trimAutoWhitespace = true
editor.trimTrailingWhitespace = true
editor.insertSpaces = true
editor.tabSize = 2
editor.detectIndentation = true

# File Settings
files.trimTrailingWhitespace = true
files.insertFinalNewline = true
files.trimFinalNewlines = true

# Language-specific settings
[*.vue]
editor.tabSize = 2
editor.insertSpaces = true

[*.ts]
editor.tabSize = 2
editor.insertSpaces = true

[*.js]
editor.tabSize = 2
editor.insertSpaces = true

[*.json]
editor.tabSize = 2
editor.insertSpaces = true

[*.pug]
editor.tabSize = 2
editor.insertSpaces = true

# Project-specific rules
- Never automatically build the project
- Never automatically start the development server
- Ask for logs instead of running commands
- Be direct and use minimal text
- Never give summaries unless explicitly requested
- Never automatically generate markdown files unless explicitly directed
- Update cursor rules when needed
- Only run npm test for tests faster than 300ms, and npm test:all for all tests
- Each microservice directory must have its own pnpm-lock.yaml
- Log all console output to './output.txt'
- Proposed fixes should be concise
- Use Google Cloud SDK (gcloud CLI) rather than AWS CLI for backup scripts
- For Nuxt components, use folder structure plus filename for auto-imported component names
